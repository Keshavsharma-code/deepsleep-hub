{
  "manifest_version": 3,
  "name": "DeepSleep Hub",
  "version": "1.0.0",
  "description": "The Universal AI Cognitive Bridge. Connects ChatGPT, Claude, and Gemini with local project memory.",
  "permissions": ["storage", "unlimitedStorage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.kimi.com/*",
        "https://grok.com/*",
        "http://localhost:*/*"
      ],
      "js": ["dist/content.js", "dist/injector.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/*", "lib/*", "icons/*", "brain.html", "brain.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
