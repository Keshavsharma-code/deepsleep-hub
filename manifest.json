{
  "manifest_version": 3,
  "name": "DeepSleep Hub",
  "version": "4.0.0",
  "description": "Universal Cross-AI Neural Memory Bridge. Persistent context for every AI.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "alarms", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "injector.js"],
      "css": ["injector.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["brain.html", "lib/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
