{
  "manifest_version": 3,
  "name": "DeepSleep Hub",
  "version": "2.0.0",
  "description": "Universal AI Memory Bridge. Connects ChatGPT, Claude, Gemini, Grok, DeepSeek, Perplexity, and Kimi — no AI ever forgets.",
  "permissions": ["storage", "unlimitedStorage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "http://localhost:*/*"
      ],
      "js": ["dist/content.js", "dist/injector.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "http://localhost:*/*"
      ],
      "js": ["dist/interceptors/network.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/*", "lib/*", "icons/*", "brain.html", "brain.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
