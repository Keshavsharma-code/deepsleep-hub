{
  "manifest_version": 3,
  "name": "DeepSleep Hub",
  "version": "5.0.0",
  "description": "Universal AI Memory Bridge with 3D Neural Cortex. Connects ChatGPT, Kimi, Grok, and Local AIs.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "alarms", "clipboardWrite"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://kimi.moonshot.cn/*",
    "https://www.kimi.com/*",
    "https://x.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://kimi.moonshot.cn/*",
        "https://www.kimi.com/*",
        "https://x.com/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["content.js", "injector.js"],
      "css": ["injector.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["brain.html", "brain.js", "lib/*", "icons/*", "styles.css", "ui-handlers.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
