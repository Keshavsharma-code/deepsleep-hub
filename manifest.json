{
  "manifest_version": 3,
  "name": "DeepSleep Hub",
  "version": "2.4.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "alarms"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://kimi.moonshot.cn/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": ["message-queue.js", "content-gpt.js", "injector.js"],
      "css": ["injector.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["message-queue.js", "content-claude.js", "injector.js"],
      "css": ["injector.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["message-queue.js", "content-gemini.js", "injector.js"],
      "css": ["injector.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://kimi.moonshot.cn/*"],
      "js": ["message-queue.js", "content-kimi.js", "injector.js"],
      "css": ["injector.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:*/*", "http://127.0.0.1:*/*"],
      "js": ["message-queue.js", "content-local.js", "injector.js"],
      "css": ["injector.css"],
      "run_at": "document_idle"
    }
  ]
}
